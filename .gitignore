node_modules

# Output
.output
.deno-deploy
.vercel
.netlify
.wrangler
/.svelte-kit
/build
/dist

# deno desktop compiled app bundles
*.app
/out/

# OS
.DS_Store
Thumbs.db

# Env
# NB: .env.local is generated by `task dev` and contains a LIVE API token.
.env
.env.*
!.env.example
!.env.test

# The throwaway timeline `task dev` writes to, so development never touches the
# real ~/.dev-stream.
/.dev-stream-dev/
# Same idea, for `task test:e2e` (see e2e/run-server.sh).
/.dev-stream-e2e/

# Playwright
/test-results/
/playwright-report/
/blob-report/

# Taskfile's checksum cache
/.task/

# Local agent-tooling session state (instance locks, session json)
/.juggler/
/.codex/
/.cursor/
/.impeccable/

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
